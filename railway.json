{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "nixpacks",
    "buildCommand": "npm install"
  },
  "deploy": {
    "numReplicas": 1,
    "sleepApplication": false,
    "restartPolicyType": "always",
    "startCommand": "node simple-server.js",
    "healthcheckPath": "/health",
    "healthcheckTimeout": 30
  }
} 